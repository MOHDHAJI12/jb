rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'mohdhaji0112@gmail.com' ||
        request.auth.token.email.lower() == 'syedimran1029@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Products ---
    match /products/{productId} {
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200
            && data.price is string && data.price.size() > 0 && data.price.size() <= 50
            && data.image is string && data.image.size() > 0 && data.image.size() <= 1500000
            && data.category is string && data.category.size() > 0 && data.category.size() <= 100
            && (!('isNew' in data) || data.isNew is bool);
      }

      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(request.resource.data) && (
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'price', 'image', 'category', 'isNew'])
      );
      allow delete: if isAdmin();
    }

    // --- Blogs ---
    match /blogs/{blogId} {
      function isValidBlog(data) {
        return data.title is string && data.title.size() > 0 && data.title.size() <= 300
            && data.date is string && data.date.size() > 0
            && data.image is string && data.image.size() > 0
            && data.excerpt is string && data.excerpt.size() > 0;
      }

      allow read: if true;
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidBlog(request.resource.data)) && isValidId(blogId);
    }

    // --- Orders ---
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.items is list && data.items.size() > 0
            && data.total is number && data.total >= 0
            && data.createdAt is string; // Using string to match current app spec
      }

      allow create: if isValidOrder(request.resource.data);
      allow list, get: if isAdmin();
    }

    // --- Showcase ---
    match /showcase/{itemId} {
      function isValidShowcase(data) {
        return data.image is string && data.image.size() > 0
            && (!('title' in data) || data.title is string)
            && (!('description' in data) || data.description is string)
            && data.createdAt is string;
      }
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Admins collection ---
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
      allow create: if isSignedIn() && (
        request.auth.token.email.lower() == 'mohdhaji0112@gmail.com' ||
        request.auth.token.email.lower() == 'syedimran1029@gmail.com'
      ) && request.auth.uid == adminId;
      allow update, delete: if false; 
    }
  }
}
